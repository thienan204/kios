// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}


model Area {
  id                 Int      @id @default(autoincrement())
  uid                String   @unique @default(uuid())
  name               String
  groupId            Int?
  group              AreaGroup? @relation(fields: [groupId], references: [id])
  startTime          String
  endTime            String
  afternoonStartTime String
  afternoonEndTime   String
  audioTemplate      String?
  printHospitalName  String?  @default("Bệnh viện Đa khoa Tỉnh")
  printGreeting      String?  @default("SỐ THỨ TỰ CỦA BẠN")
  printFooter        String?  @default("Vui lòng ngồi chờ đến lượt gọi.")
  kioskDeviceId      String?
  audioDeviceId      String?
  tvDeviceId         String?
  ticketResetType    String   @default("ALL_DAY")
  isIssuePaused      Boolean  @default(false)
  hasIssueLimit      Boolean  @default(false)
  issueLimitMorning  Int      @default(0)
  issueLimitAfternoon Int     @default(0)
  kioskPin           String   @default("123456")
  desks              Desk[]
  tickets            Ticket[]
}

model Desk {
  id              Int          @id @default(autoincrement()) 
  name            String       
  areaId          Int          
  area            Area         @relation(fields: [areaId], references: [id])
  status          DeskStatus   @default(ACTIVE)
  tickets         Ticket[]
}

model Ticket {
  id               Int       @id @default(autoincrement())
  ticketNumber     Int       
  areaId           Int       
  area             Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)
  status           TicketStatus @default(WAITING)
  issuedAt         DateTime  @default(now())
  calledAt         DateTime? 
  completedAt      DateTime? 
  phoneNumber      String?   
  customerName     String?   
  deskId           Int?      
  desk             Desk?     @relation(fields: [deskId], references: [id])
  missedCallCount  Int       @default(0) 
}

model AreaGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  areas     Area[]
}

enum DeskStatus {
  ACTIVE
  PAUSED
}

enum TicketStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}

model SystemSetting {
  key   String @id
  value String
}

// ==========================================
// MODULE: TỰ ĐĂNG KÝ KHÁM
// ==========================================

model SelfRegDevice {
  id            Int      @id @default(autoincrement())
  name          String   
  ipAddress     String?  
  macAddress    String?  @unique 
  location      String?  
  readerModel   String?  // Hãng/Model Đầu đọc CCCD (VD: Newland, ACR122U)
  cameraModel   String?  // Hãng/Model Camera (VD: Logitech HD)
  status        String   @default("OFFLINE") 
  allowBHYT     Boolean  @default(true)      
  allowService  Boolean  @default(true)      
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SelfRegHISConfig {
  id           Int      @id @default(autoincrement())
  endpointUrl  String   
  httpMethod   String   @default("POST")
  headers      String?  
  fieldMapping String?  
  formLayout   String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

